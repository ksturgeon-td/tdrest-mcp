# Elastic Compute API (Teradata)
ELASTIC_COMPUTE_BASE_URL=https://preprod.globalcompute.qateradatacloud.com

# Vector Store API (Teradata)
VECTOR_STORE_BASE_URL=https://api.vectorstore.qateradatacloud.com

# Custom service base URLs (add any services by appending _BASE_URL to the name)
# Example: for a service called "my-api", add MY_API_BASE_URL
# These will be automatically discovered and made available to Claude
# MY_API_BASE_URL=https://api.example.com
# ANOTHER_SERVICE_BASE_URL=https://service.example.com

# Request timeout (milliseconds)
REQUEST_TIMEOUT=30000

# Default Authentication (optional - set at session level with set_auth tool if not configured here)
# Automatically applied to all requests unless overridden per-request or via set_auth
# Bearer token example:
# DEFAULT_AUTH_TYPE=bearer
# DEFAULT_AUTH_TOKEN=eyJhbGc...very-long-jwt-token...

# Basic auth example:
# DEFAULT_AUTH_TYPE=basic
# DEFAULT_AUTH_USERNAME=myuser
# DEFAULT_AUTH_PASSWORD=mypassword

# Custom header example:
# DEFAULT_AUTH_TYPE=custom
# DEFAULT_AUTH_HEADER_NAME=X-API-Key
# DEFAULT_AUTH_HEADER_VALUE=your-api-key-here

# Socks5 Proxy (optional - set at session level with set_proxy tool if not configured here)
# SOCKS5_PROXY_HOST=proxy.corp.com
# SOCKS5_PROXY_PORT=1080
# SOCKS5_PROXY_USERNAME=myuser
# SOCKS5_PROXY_PASSWORD=mypass
