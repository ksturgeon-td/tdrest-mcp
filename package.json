{
  "name": "tdrest-mcp",
  "version": "0.1.0",
  "description": "Lightweight MCP server for REST API calls with auth headers, Socks5 proxy, and multipart support",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "start": "node dist/index.js"
  },
  "keywords": ["mcp", "rest", "api", "proxy", "auth"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "form-data": "^4.0.0",
    "handlebars": "^4.7.7",
    "socks-proxy-agent": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^7.0.0",
    "vitest": "^1.0.0"
  }
}
